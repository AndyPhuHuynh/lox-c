for (var i = 0; i < 4; i = i + 1) {
    if (i > 2) {
        print "i greater than 2, breaking for loop";
        break;
    }
    print i;
}

var i = 0;
while (i < 4) {
    if (i > 2) {
        print "i greater than 2, breaking for loop";
        i = i + 1;
        break;
    }
    print i;
    i = i + 1;
}